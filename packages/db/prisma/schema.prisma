// Screener data model — a view/aggregation over an IMMUTABLE event log.
// Screenings (+ findings, images, questionnaire) are write-once; FollowUp is the
// only mutable record. Status/role/level fields are plain strings validated by
// the TS unions in @pinequest/types — NO Prisma enums or scalar lists, so the
// same schema runs on SQLite (dev) and PostgreSQL (prod).

datasource db {
  provider = "sqlite"

}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// People & access
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  role         String // 'screener' | 'dentist' | 'follow_up' | 'admin'
  passwordHash String?
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  screenings        Screening[]      @relation("ScreenedBy")
  followUpsAssigned FollowUp[]       @relation("FollowUpAssignee")
  followUpUpdates   FollowUp[]       @relation("FollowUpUpdatedBy")
  contentVersions   ContentVersion[]
  auditEntries      AuditLog[]
  reviews           ScreeningReview[]
  scopes            UserScope[]
  parentLinks       ParentChildLink[]
}

// Capability × Coverage split: roles = capability; UserScope = what they can see.
// A teacher gets (class, classId); school doctor gets (school, schoolId);
// a parent gets (child, childKey). One user can hold multiple grants.
model UserScope {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  scopeKind String   // 'child' | 'class' | 'school' | 'district'
  scopeId   String
  grantedAt DateTime @default(now())
  grantedBy String?

  @@unique([userId, scopeKind, scopeId])
  @@index([userId])
  @@index([scopeKind, scopeId])
}

// Links a parent User to their child's anonymous childKey.
// PII stays here (same boundary as Child). Never flows into Screening payload.
model ParentChildLink {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  childKey  String   // anonymous hash — no name stored here
  schoolId  String
  consentAt DateTime

  @@unique([userId, childKey])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Roster (the ONLY place PII lives)
// ---------------------------------------------------------------------------

model School {
  id        String   @id @default(uuid())
  name      String
  soumCode  String?
  district  String?
  createdAt DateTime @default(now())

  classes  SchoolClass[]
  children Child[]
  users    User[]
}

model SchoolClass {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String
  seasonId    String
  gradeLevel  Int?
  // Carry-forward: a new-season class points back at the class it was promoted from.
  sourceClassId String?
  sourceClass   SchoolClass?  @relation("CarryForward", fields: [sourceClassId], references: [id])
  carriedTo     SchoolClass[] @relation("CarryForward")
  // Screener-set schedule for the next-season screening visit + optional reminder phone.
  scheduledAt   DateTime?
  reminderPhone String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  children Child[]

  @@unique([schoolId, name, seasonId])
}

model Child {
  id              String    @id @default(uuid())
  classId         String
  class           SchoolClass @relation(fields: [classId], references: [id])
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id])
  childKey        String // deterministic anonymous hash; bridges seasons
  firstName       String // PII
  lastName        String // PII
  birthYear       Int
  rosterSlot      Int
  gender          String? // 'M' | 'F'
  guardianPhone   String? // PII
  guardianEmail   String? // PII — parent summary delivery
  consentObtained Boolean   @default(false)
  consentAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@unique([classId, rosterSlot])
  @@unique([classId, childKey])
  @@index([childKey])
}

// ---------------------------------------------------------------------------
// Immutable screening event (write-once)
// ---------------------------------------------------------------------------

// Screenings reference the anonymous childKey (not a hard FK to Child) so an
// off-roster / not-yet-synced child still produces a valid event.
model Screening {
  id           String  @id // client-generated UUID == sync idempotency key
  childKey     String
  classId      String
  schoolId     String
  seasonId     String
  screenedById String
  screenedBy   User    @relation("ScreenedBy", fields: [screenedById], references: [id])

  // Triage (derived in TS, persisted with the immutable event)
  triageLevel            String // 'green' | 'yellow' | 'red'
  triageScore            Float
  triageConfidentWording Boolean
  triageReason           String?

  modelName        String
  modelVersion     String?
  contentVersionId String
  contentVersion   ContentVersion @relation(fields: [contentVersionId], references: [id])

  capturedAt DateTime // device wall-clock
  deviceId   String?
  createdAt  DateTime  @default(now()) // server receipt time
  syncedAt   DateTime?

  findings      ToothFinding[]
  images        ScreeningImage[]
  questionnaire Questionnaire?
  review        ScreeningReview?

  @@index([childKey])
  @@index([childKey, seasonId])
  @@index([schoolId, seasonId])
}

// Dentist confirm/override of a screening's triage. The screening stays
// immutable; this is the audited human judgement layered on top (one per screening).
model ScreeningReview {
  id             String    @id @default(uuid())
  screeningId    String    @unique
  screening      Screening @relation(fields: [screeningId], references: [id])
  reviewedById   String
  reviewedBy     User      @relation(fields: [reviewedById], references: [id])
  confirmedLevel String // dentist's triage: 'green' | 'yellow' | 'red'
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ScreeningImage {
  id          String    @id @default(uuid())
  screeningId String
  screening   Screening @relation(fields: [screeningId], references: [id])
  ref         String // storage key (synced) or local URI (offline)
  order       Int       @default(0)
}

model ToothFinding {
  id           String    @id // client-generated
  screeningId  String
  screening    Screening @relation(fields: [screeningId], references: [id])
  fdi          Int? // FDI tooth code 11–48; null until localized
  className    String // 'caries' | 'cavity' | 'crack'
  classId      Int
  confidence   Float
  boxX1        Float
  boxY1        Float
  boxX2        Float
  boxY2        Float
  longitudinal String? // 'new' | 'worsened' | 'stable' | 'resolved'
}

model Questionnaire {
  id                          String    @id @default(uuid())
  screeningId                 String    @unique
  screening                   Screening @relation(fields: [screeningId], references: [id])
  isAdult                     Boolean   @default(false)
  // Shared danger signs — both age groups (children: all 5; adults: Q1–Q2 only)
  swelling                    Boolean?
  painDisturbingSleepOrEating Boolean?
  // Child-only danger signs (age < 18)
  fever                       Boolean?
  gumPimpleOrFistula          Boolean?
  trauma                      Boolean?
  // Adult-specific context (age >= 18)
  bleedingGums                Boolean?
  smoker                      Boolean?
  lastCheckupAdult            String?   // 'never' | 'lt_1y' | 'gt_1y'
}

// ---------------------------------------------------------------------------
// FollowUp — the ONLY mutable record (two-way sync, optimistic-locked)
// ---------------------------------------------------------------------------

model FollowUp {
  id                  String    @id @default(uuid())
  childKey            String    @unique // one running follow-up per child
  schoolId            String
  status              String    @default("flagged")
  assignedToId        String?
  assignedTo          User?     @relation("FollowUpAssignee", fields: [assignedToId], references: [id])
  appointmentAt       DateTime?
  notifiedAt          DateTime?
  notificationChannel String? // 'sms' | 'call' | 'in_person'
  notes               String?
  updatedAt           DateTime  @updatedAt
  updatedById         String
  updatedBy           User      @relation("FollowUpUpdatedBy", fields: [updatedById], references: [id])
  version             Int       @default(0)

  @@index([schoolId, status])
}

// ---------------------------------------------------------------------------
// Content & audit
// ---------------------------------------------------------------------------

model ContentVersion {
  id            String   @id @default(uuid())
  version       String
  locale        String
  publishedAt   DateTime @default(now())
  publishedById String
  publishedBy   User     @relation(fields: [publishedById], references: [id])

  screenings Screening[]
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  oldValue   String? // JSON string
  newValue   String? // JSON string
  createdAt  DateTime @default(now())
}
