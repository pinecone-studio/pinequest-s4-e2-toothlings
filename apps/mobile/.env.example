# Copy to `.env` (gitignored) and keep as-is to use the shared deployed API.
# Mobile (React Native) has no CORS constraints, so this Just Works from any device.
EXPO_PUBLIC_API_URL=https://screener-api.ariunzul.workers.dev

# For local API dev instead, point at your machine's LAN IP (not localhost — a
# physical phone can't reach your laptop's localhost), e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8787
