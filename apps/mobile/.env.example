# Copy to `.env` (gitignored). Expo reads EXPO_PUBLIC_* at build/runtime.

# Backend API (Cloudflare Worker). The deployed Worker is always on.
EXPO_PUBLIC_API_URL=https://screener-api.ariunzul.workers.dev

# On-device ONNX model, downloaded once and cached for offline use.
# Always-on hosted model (HF Spaces) — works on any network, no LAN/laptop needed.
EXPO_PUBLIC_MODEL_URL=https://nerunnee-toothlings-inference.hf.space/model.onnx
