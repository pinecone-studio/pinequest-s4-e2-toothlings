# Copy to `.env` (gitignored). Used by `next dev` / `pnpm run deploy`.

# Backend API (Cloudflare Worker). The deployed Worker is always on.
NEXT_PUBLIC_API_URL=https://screener-api.ariunzul.workers.dev

# Where the local Next.js /api/inference/analyze route proxies image analysis.
# Always-on hosted model (HF Spaces) — no local Python server needed.
# For local model dev instead: run apps/model and use http://127.0.0.1:8765/analyze
INFERENCE_URL=https://nerunnee-toothlings-inference.hf.space/analyze
