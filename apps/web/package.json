    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.62.7",
    "@tensorflow/tfjs": "^4.22.0",
    "ahrs": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.25",
    "lucide-react": "^1.21.0",
    "next": "^15.1.3",
    "peerjs": "^1.5.5",
    "radix-ui": "^1.6.0",
